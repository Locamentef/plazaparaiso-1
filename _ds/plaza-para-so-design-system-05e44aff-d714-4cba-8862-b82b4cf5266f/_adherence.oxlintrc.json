{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/events/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Esther|Montserrat|Anton))/i]",
        "message": "Font not provided by the design system. Available: Esther, Montserrat, Anton."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:shape|color|size|rotate|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: shape, color, size, rotate, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:burst|circle)$/]",
        "message": "<Badge> shape must be one of 'burst' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:orange|red|navy|amber)$/]",
        "message": "<Badge> color must be one of 'orange' | 'red' | 'navy' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|as|iconRight|iconLeft|fullWidth|disabled|href|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, as, iconRight, iconLeft, fullWidth, disabled, href, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|red|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'red' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|label|dates|place|style|key|ref|className|style|children)$/]",
        "message": "<CategoryBar> doesn't accept that prop. Declared props: category, label, dates, place, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryBar'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:musica|teatro|gastro|ocio)$/]",
        "message": "<CategoryBar> category must be one of 'musica' | 'teatro' | 'gastro' | 'ocio'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|name|date|kicker|category|href|ratio|showWave|style|key|ref|className|style|children)$/]",
        "message": "<EventCard> doesn't accept that prop. Declared props: image, name, date, kicker, category, href, ratio, showWave, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventCard'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:musica|teatro|gastro|ocio)$/]",
        "message": "<EventCard> category must be one of 'musica' | 'teatro' | 'gastro' | 'ocio'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|date|kicker|align|size|style|key|ref|className|style|children)$/]",
        "message": "<EventLabel> doesn't accept that prop. Declared props: name, date, kicker, align, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventLabel'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<EventLabel> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventLabel'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<EventLabel> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|color|src|height|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, color, src, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:compact|full)$/]",
        "message": "<Logo> variant must be one of 'compact' | 'full'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:navy|cream|orange|red|white)$/]",
        "message": "<Logo> color must be one of 'navy' | 'cream' | 'orange' | 'red' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|children|size|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: category, children, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:musica|teatro|gastro|ocio|cream)$/]",
        "message": "<Tag> category must be one of 'musica' | 'teatro' | 'gastro' | 'ocio' | 'cream'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Tag> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WaveDivider'] > JSXAttribute > JSXIdentifier[name!=/^(?:flip|height|palette|background|style|key|ref|className|style|children)$/]",
        "message": "<WaveDivider> doesn't accept that prop. Declared props: flip, height, palette, background, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
