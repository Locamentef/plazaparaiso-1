# Netlify cache headers — Plaza Paraíso
# Atomic deploys make long-cache safe for versioned assets.

# Fonts, images, optimised assets — immutable 1 year
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/assets/img/*
  Cache-Control: public, max-age=31536000, immutable

/assets/opt/*
  Cache-Control: public, max-age=31536000, immutable

/assets/video/*
  Cache-Control: public, max-age=2592000

# User uploads — 30 days
/uploads/*
  Cache-Control: public, max-age=2592000

# Favicons — 7 days
/favicon*
  Cache-Control: public, max-age=604800

# CSS & JS — 1 day (short enough to pick up fixes quickly)
/*.css
  Cache-Control: public, max-age=86400

/*.js
  Cache-Control: public, max-age=86400

# HTML — 1 hour + revalidate
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

/
  Cache-Control: public, max-age=3600, must-revalidate
